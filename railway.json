{ 
  "$schema": "https://railway.app/railway.schema.json", 
  "build": { 
    "builder": "nixpacks", 
    "buildCommand": "cd server && npm install" 
  }, 
  "deploy": { 
    "numReplicas": 1, 
    "startCommand": "cd server && npm start", 
    "restartPolicyType": "ON_FAILURE", 
    "restartPolicyMaxRetries": 3 
  } 
} 
